<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AStar.Dev.OneDrive.Sync.Client.ViewModels"
             x:Class="AStar.Dev.OneDrive.Sync.Client.Controls.AccountStatusBar"
             x:DataType="vm:StatusBarViewModel">

    <Border Background="{DynamicResource BackgroundStatusBarBrush}"
            BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            Height="{StaticResource StatusBarHeight}">

        <Grid>
            <TextBlock IsVisible="{Binding !HasAccount}"
                       Text="No account selected"
                       FontSize="{StaticResource FontSizeXs}"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       VerticalAlignment="Center"
                       Margin="12,0"/>

            <Grid IsVisible="{Binding HasAccount}"
                  ColumnDefinitions="Auto,1,Auto,*,Auto,12,Auto,12,Auto">

                <Ellipse Grid.Column="0"
                         Width="7" Height="7"
                         Margin="10,0,5,0"
                         VerticalAlignment="Center"
                         Fill="{DynamicResource TextAccentBrush}"/>

                <TextBlock Grid.Column="0"
                           Margin="22,0,8,0"
                           Text="{Binding AccountEmail}"
                           FontSize="{StaticResource FontSizeXs}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="180"/>

                <Rectangle Grid.Column="1"
                           Width="1" Height="12"
                           Fill="{DynamicResource BorderSubtleBrush}"
                           VerticalAlignment="Center"
                           Margin="4,0"/>

                <TextBlock Grid.Column="2"
                           Margin="6,0"
                           Text="{Binding StatusLabel}"
                           FontSize="{StaticResource FontSizeXs}"
                           Foreground="{Binding SyncState, Converter={StaticResource SyncStateToForegroundConverter}}"
                           VerticalAlignment="Center"/>

                <ProgressBar Grid.Column="3"
                             Margin="8,0"
                             Height="2"
                             VerticalAlignment="Center"
                             IsIndeterminate="True"
                             IsVisible="{Binding IsSyncing}"
                             Foreground="{DynamicResource TextAccentBrush}"
                             Background="Transparent"/>

                <TextBlock Grid.Column="4"
                           Text="{Binding LastSyncText}"
                           FontSize="{StaticResource FontSizeXs}"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Column="6"
                           Text="{Binding StorageUsedText}"
                           FontSize="{StaticResource FontSizeXs}"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Column="8"
                           Text="{Binding ConflictPolicyText}"
                           FontSize="{StaticResource FontSizeXs}"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"/>

            </Grid>
        </Grid>

    </Border>

</UserControl>