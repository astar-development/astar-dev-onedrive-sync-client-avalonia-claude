<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:AStar.Dev.OneDrive.Sync.Client.ViewModels"
        xmlns:controls="clr-namespace:AStar.Dev.OneDrive.Sync.Client.Controls"
        xmlns:views="clr-namespace:AStar.Dev.OneDrive.Sync.Client.Views"
        xmlns:local="clr-namespace:AStar.Dev.OneDrive.Sync.Client"
        mc:Ignorable="d"
        x:Class="AStar.Dev.OneDrive.Sync.Client.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="OneDrive Sync"
        Width="1100" Height="700"
        MinWidth="800" MinHeight="520"
        Icon="avares://AStar.Dev.OneDrive.Sync.Client/Assets/astar.png"
        Background="{DynamicResource BackgroundPrimaryBrush}"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="-1">

    <Window.Resources>
        <Geometry x:Key="IconDashboard">
            M3,3 H10 V10 H3 V3 Z
            M14,3 H21 V10 H14 V3 Z
            M3,14 H10 V21 H3 V14 Z
            M14,14 H21 V21 H14 V14 Z
        </Geometry>
        <Geometry x:Key="IconFiles">
            M10,4 H4 C2.9,4 2,4.9 2,6 V18 C2,19.1 2.9,20 4,20 H20 C21.1,20 22,19.1 22,18
            V8 C22,6.9 21.1,6 20,6 H12 L10,4 Z
        </Geometry>
        <Geometry x:Key="IconActivity">
            M13,3 H11 V13 H13 V3 Z
            M18.66,4.34 L17.24,5.76 C18.99,7.5 20,9.86 20,12.5
            C20,17.19 16.19,21 11.5,21 C6.81,21 3,17.19 3,12.5
            C3,8.08 6.41,4.42 10.75,4.04 V2.02
            C5.31,2.42 1,7.02 1,12.5 C1,18.3 5.7,23 11.5,23
            C17.3,23 22,18.3 22,12.5 C22,9.27 20.6,6.36 18.66,4.34 Z
        </Geometry>
        <Geometry x:Key="IconAccounts">
            M12,12 C14.21,12 16,10.21 16,8 C16,5.79 14.21,4 12,4
            C9.79,4 8,5.79 8,8 C8,10.21 9.79,12 12,12 Z
            M12,14 C9.33,14 4,15.34 4,18 V20 H20 V18 C20,15.34 14.67,14 12,14 Z
        </Geometry>
        <Geometry x:Key="IconSettings">
            M19.14,12.94 C19.18,12.64 19.2,12.33 19.2,12
            C19.2,11.68 19.18,11.36 19.13,11.06 L21.16,9.48
            C21.34,9.34 21.39,9.07 21.28,8.87 L19.36,5.55
            C19.24,5.33 18.99,5.26 18.77,5.33 L16.38,6.29
            C15.88,5.91 15.35,5.59 14.76,5.35 L14.4,2.81
            C14.36,2.57 14.15,2.4 13.9,2.4 H10.1
            C9.85,2.4 9.65,2.57 9.61,2.81 L9.25,5.35
            C8.66,5.59 8.12,5.92 7.63,6.29 L5.24,5.33
            C5.01,5.25 4.76,5.33 4.64,5.55 L2.72,8.87
            C2.6,9.08 2.65,9.34 2.84,9.48 L4.87,11.06
            C4.82,11.36 4.8,11.69 4.8,12 C4.8,12.31 4.82,12.64 4.87,12.94
            L2.84,14.52 C2.66,14.66 2.6,14.93 2.72,15.13
            L4.64,18.45 C4.76,18.67 5.01,18.74 5.24,18.67
            L7.63,17.71 C8.13,18.09 8.66,18.41 9.25,18.65
            L9.61,21.19 C9.65,21.43 9.85,21.6 10.1,21.6 H13.9
            C14.15,21.6 14.36,21.43 14.39,21.19 L14.75,18.65
            C15.34,18.41 15.88,18.08 16.37,17.71 L18.76,18.67
            C18.99,18.75 19.24,18.67 19.36,18.45 L21.28,15.13
            C21.4,14.91 21.34,14.66 21.15,14.52 L19.14,12.94 Z
            M12,15.6 C10.02,15.6 8.4,13.98 8.4,12
            C8.4,10.02 10.02,8.4 12,8.4 C13.98,8.4 15.6,10.02 15.6,12
            C15.6,13.98 13.98,15.6 12,15.6 Z
        </Geometry>
    </Window.Resources>

    <!-- Root: Row 0 = working area, Row 1 = status bar -->
    <Grid RowDefinitions="*,Auto">

        <!-- ── Row 0 — three-column working area ── -->
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,Auto,*">

            <!-- Column 0 — Icon rail -->
            <Border Grid.Column="0"
                    Background="{DynamicResource BackgroundRailBrush}"
                    BorderThickness="0,0,1,0"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    Width="{StaticResource IconRailWidth}">
                <DockPanel LastChildFill="False">

                    <Border DockPanel.Dock="Top"
                            Height="{StaticResource IconRailWidth}"
                            Width="{StaticResource IconRailWidth}"
                            ToolTip.Tip="OneDrive Sync">
                        <Viewbox Width="22" Height="22">
                            <Canvas Width="24" Height="24">
                                <Path Fill="{DynamicResource TextAccentBrush}"
                                      Data="M19.35,10.04 C18.67,6.59 15.64,4 12,4
                                            C9.11,4 6.6,5.64 5.35,8.04
                                            C2.34,8.36 0,10.91 0,14
                                            C0,17.31 2.69,20 6,20 H19
                                            C21.76,20 24,17.76 24,15
                                            C24,12.36 21.95,10.22 19.35,10.04 Z"/>
                            </Canvas>
                        </Viewbox>
                    </Border>

                    <StackPanel DockPanel.Dock="Top"
                                Spacing="2"
                                Margin="0,8,0,0">
                        <controls:IconRailButton
                            IconData="{StaticResource IconDashboard}"
                            TooltipLabel="Dashboard — all accounts overview"
                            IsActive="{Binding IsDashboardActive}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="{x:Static local:NavSection.Dashboard}"/>
                        <controls:IconRailButton
                            IconData="{StaticResource IconFiles}"
                            TooltipLabel="Files — browse and manage sync folders"
                            IsActive="{Binding IsFilesActive}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="{x:Static local:NavSection.Files}"/>
                        <controls:IconRailButton
                            IconData="{StaticResource IconActivity}"
                            TooltipLabel="Activity — delta log and conflicts"
                            IsActive="{Binding IsActivityActive}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="{x:Static local:NavSection.Activity}"/>
                        <controls:IconRailButton
                            IconData="{StaticResource IconAccounts}"
                            TooltipLabel="Accounts — add or remove OneDrive accounts"
                            IsActive="{Binding IsAccountsActive}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="{x:Static local:NavSection.Accounts}"/>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Bottom"
                                Spacing="2"
                                Margin="0,0,0,8">
                        <controls:IconRailButton
                            IconData="{StaticResource IconSettings}"
                            TooltipLabel="Settings — theme, language and sync policy"
                            IsActive="{Binding IsSettingsActive}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="{x:Static local:NavSection.Settings}"/>
                    </StackPanel>

                </DockPanel>
            </Border>

            <!-- Column 1 — Account panel -->
            <Border Grid.Column="1"
                    Width="{StaticResource AccountPanelWidth}"
                    Background="{DynamicResource BackgroundAccountPanelBrush}"
                    BorderThickness="0,0,1,0"
                    BorderBrush="{DynamicResource BorderSubtleBrush}">
                <DockPanel LastChildFill="True">

                    <Border DockPanel.Dock="Top"
                            Height="{StaticResource IconRailWidth}"
                            Padding="12,0">
                        <TextBlock Text="Accounts"
                                   FontSize="{StaticResource FontSizeSm}"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   VerticalAlignment="Center"
                                   LetterSpacing="0.8"/>
                    </Border>

                    <Rectangle DockPanel.Dock="Top"
                               Height="1"
                               Fill="{DynamicResource BorderSubtleBrush}"/>

                    <Border DockPanel.Dock="Bottom"
                            BorderThickness="0,1,0,0"
                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                            Padding="8">
                        <Button HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Padding="0,6"
                                CornerRadius="{StaticResource RadiusMd}"
                                Background="Transparent"
                                BorderBrush="{DynamicResource BorderDefaultBrush}"
                                BorderThickness="1"
                                Command="{Binding AddAccountCommand}"
                                Cursor="Hand">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="+"
                                           FontSize="{StaticResource FontSizeLg}"
                                           Foreground="{DynamicResource TextAccentBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Add account"
                                           FontSize="{StaticResource FontSizeSm}"
                                           Foreground="{DynamicResource TextAccentBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <ScrollViewer DockPanel.Dock="Top"
                                VerticalScrollBarVisibility="Auto"
                                HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="0,4">

                            <!-- Empty state -->
                            <StackPanel IsVisible="{Binding !Accounts.HasAccounts}"
                                        HorizontalAlignment="Center"
                                        Margin="12,32,12,0"
                                        Spacing="6">
                                <TextBlock Text="No accounts yet"
                                        FontSize="{StaticResource FontSizeSm}"
                                        Foreground="{DynamicResource TextTertiaryBrush}"
                                        HorizontalAlignment="Center"
                                        TextWrapping="Wrap"
                                        TextAlignment="Center"/>
                                <TextBlock Text="Add a Microsoft account to get started."
                                        FontSize="{StaticResource FontSizeXs}"
                                        Foreground="{DynamicResource TextTertiaryBrush}"
                                        HorizontalAlignment="Center"
                                        TextWrapping="Wrap"
                                        TextAlignment="Center"/>
                            </StackPanel>

                            <!-- Account list -->
                            <ItemsControl IsVisible="{Binding Accounts.HasAccounts}"
                                        ItemsSource="{Binding Accounts.Accounts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:AccountCardViewModel">
                                        <Button Background="Transparent"
                                                BorderThickness="0"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                Padding="8,4"
                                                Command="{Binding SelectCommand}">
                                            <Grid ColumnDefinitions="Auto,*,Auto">

                                                <!-- Accent dot -->
                                                <Ellipse Grid.Column="0"
                                                        Width="8" Height="8"
                                                        Margin="4,0,8,0"
                                                        VerticalAlignment="Center">
                                                    <Ellipse.Fill>
                                                        <SolidColorBrush Color="{Binding AccentColor}"/>
                                                    </Ellipse.Fill>
                                                </Ellipse>

                                                <!-- Email -->
                                                <TextBlock Grid.Column="1"
                                                        Text="{Binding Email}"
                                                        FontSize="{StaticResource FontSizeXs}"
                                                        Foreground="{DynamicResource TextPrimaryBrush}"
                                                        VerticalAlignment="Center"
                                                        TextTrimming="CharacterEllipsis"/>

                                                <!-- Active indicator -->
                                                <Ellipse Grid.Column="2"
                                                        Width="6" Height="6"
                                                        Margin="4,0"
                                                        VerticalAlignment="Center"
                                                        IsVisible="{Binding IsActive}">
                                                    <Ellipse.Fill>
                                                        <SolidColorBrush Color="{Binding AccentColor}"/>
                                                    </Ellipse.Fill>
                                                </Ellipse>

                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </ScrollViewer>

                </DockPanel>
            </Border>

            <!-- Column 2 — Main content area -->
            <Grid Grid.Column="2"
                Background="{DynamicResource BackgroundPrimaryBrush}">
                <ContentControl Content="{Binding ActiveView}"/>
            </Grid>

        </Grid>
        <!-- ── end Row 0 three-column grid ── -->

        <!-- ── Row 1 — Status bar ── -->
        <Border Grid.Row="1"
                Background="{DynamicResource BackgroundStatusBarBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                Height="{StaticResource StatusBarHeight}"
                DataContext="{Binding StatusBar}">
            <TextBlock IsVisible="{Binding !HasAccount}"
                       Text="No account selected"
                       FontSize="{StaticResource FontSizeXs}"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       VerticalAlignment="Center"
                       Margin="12,0"/>
        </Border>

    </Grid>

</Window>